namespace Samples.TypeChecker.EnumDeclaration

enum Color : byte {
  Red = 1,
  Crimson = Red,
  Green,
  Blue = 4,
  Purple = Red | Blue
}

let favorite: Color = Color.Red | Color.Blue

let blueOnly: Color = favorite & Color.Blue

let toggled: Color = favorite ^ Color.Blue

let inverted: Color = ~favorite

fun choose(): Color =
  favorite ^ Color.Red
