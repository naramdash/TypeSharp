namespace Samples.MultiplicativeCompoundAssignment

export fun adjust(value: int, factor: short): int {
  let mut result = value
  result *= factor
  result /= 2
  result %= 5
  result
}

export fun adjustLong(value: long, divisor: int): long {
  let mut result = value
  result *= 3
  result /= divisor
  result %= 7
  result
}

export fun scaleFloat(value: float, factor: int): float {
  let mut result = value
  result *= factor
  result /= factor
  result %= 2
  result
}

export fun scaleDouble(value: double, factor: float): double {
  let mut result = value
  result *= factor
  result /= 2
  result %= factor
  result
}

export fun scaleDecimal(value: decimal, factor: int): decimal {
  let mut result = value
  result *= factor
  result /= 2m
  result %= factor
  result
}
