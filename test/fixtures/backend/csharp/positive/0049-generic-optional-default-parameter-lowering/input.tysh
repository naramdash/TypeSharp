namespace Samples.GenericOptionalDefaultParameterLowering

fun choose<T>(value: T, fallback: string = "fallback"): T = value

fun flag<T>(value: T, enabled: bool = true): bool = enabled

fun amount<T>(value: T, count: int = 3): int = count

fun maybe<T>(value: T, label: string? = null): string? = label

fun decorate<T>(value: T, prefix: string = "item"): string = prefix

export fun main(): string {
  let direct: string = choose("value")
  let explicitValue: int = choose<int>(42)
  let full: string = choose("value", "manual")
  let namedDefault: string = choose(value: "named")
  let piped: string = "pipe" |> choose()
  let pipedExplicit: int = 7 |> choose<int>()
  let flagText = flag("value").ToString()
  let amountText = amount("value").ToString()
  let maybeValue = maybe("value")
  let decorated = "value" |> decorate()
  direct + explicitValue.ToString() + full + namedDefault + piped + pipedExplicit.ToString() + flagText + amountText + (maybeValue ?? "") + decorated
}
